<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/listaAlumnosRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/home_background"
    android:orientation="vertical"
    tools:context=".ListaAlumnosActivity">

    <include layout="@layout/view_app_toolbar" />

    <TextView
        android:id="@+id/txtResumenAula"
        style="@style/TextAppearance.App.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_screen"
        android:paddingBottom="@dimen/spacing_sm"
        tools:text="Primaria · 3° B · Turno Día" />

    <ProgressBar
        android:id="@+id/progressAlumnos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_lg" />

    <TextView
        android:id="@+id/txtEstadoAlumnos"
        style="@style/TextAppearance.App.Body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="@dimen/spacing_screen"
        android:visibility="gone"
        tools:text="No hay alumnos en esta aula"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerAlumnos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_lg"
        android:visibility="gone"
        tools:listitem="@layout/item_alumno"
        tools:visibility="visible" />
</LinearLayout>
