<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/appToolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_header"
    android:elevation="6dp"
    android:gravity="center_vertical"
    android:minHeight="?attr/actionBarSize"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_xs"
    android:paddingTop="@dimen/spacing_sm"
    android:paddingEnd="@dimen/spacing_screen"
    android:paddingBottom="@dimen/spacing_md">

    <ImageButton
        android:id="@+id/btnToolbarBack"
        android:layout_width="@dimen/toolbar_icon"
        android:layout_height="@dimen/toolbar_icon"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/desc_volver"
        android:padding="12dp"
        android:src="@drawable/ic_arrow_back" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xs">

        <TextView
            android:id="@+id/txtToolbarTitle"
            style="@style/Widget.App.ToolbarTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/txtToolbarSubtitle"
            style="@style/Widget.App.ToolbarSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
